{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "x",
  "compatibility_date": "2025-09-27",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "src",
    "html_handling": "drop-html-extension",
    "not_found_handling": "404-page"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
